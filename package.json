        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.6.2",
        "@types/pako": "^2.0.4",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^9.0.0",
        "eslint-plugin-svelte": "^2.46.0",
        "globals": "^15.0.0",
        "happy-dom": "^20.9.0",
        "jsdom": "^29.1.1",
        "prettier": "^3.0.0",
        "prettier-plugin-svelte": "^3.0.0",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.0",
